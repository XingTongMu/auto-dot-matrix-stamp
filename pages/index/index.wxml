<!-- ============================================================
  AI智能印章 - 首页 (pages/index/index.wxml)
  功能：图片选择 → 点阵处理 → 蓝牙同步
============================================================ -->
<view class="page-container">

  <!-- ========== 顶部标题区域 ========== -->
  <view class="header">
    <text class="title">⚡ AI 智能印章</text>
    <text class="subtitle">图片 → 32×32 点阵 → 蓝牙同步至硬件</text>
  </view>

  <!-- ========== 主要操作区域 ========== -->
  <view class="main-section">

    <!-- 步骤1：选择图片 + 模式切换 -->
    <view class="step-card">
      <view class="step-header">
        <text class="step-num">①</text>
        <text class="step-title">选择图片</text>
      </view>

      <!-- 处理模式切换（三选一） -->
      <view class="mode-switch">
        <view class="mode-option {{processMode === 'dither' ? 'mode-active' : ''}}"
              bindtap="switchMode" data-mode="dither">
          <text class="mode-icon">🖼</text>
          <text class="mode-label">照片</text>
          <text class="mode-desc">纯灰度抖动</text>
        </view>
        <view class="mode-option {{processMode === 'edge-aware' ? 'mode-active' : ''}}"
              bindtap="switchMode" data-mode="edge-aware">
          <text class="mode-icon">✨</text>
          <text class="mode-label">边缘感知</text>
          <text class="mode-desc">推荐</text>
        </view>
        <view class="mode-option {{processMode === 'edge' ? 'mode-active' : ''}}"
              bindtap="switchMode" data-mode="edge">
          <text class="mode-icon">🏅</text>
          <text class="mode-label">徽章</text>
          <text class="mode-desc">素描融合</text>
        </view>
      </view>

      <button class="btn btn-select" bindtap="chooseImage" disabled="{{processing}}">
        <text>{{imageSelected ? '✅ 已选择，点击重新选择' : '📷 选择图片'}}</text>
      </button>
    </view>

    <!-- 步骤2：预览点阵处理效果 -->
    <!-- 注意：canvas 必须始终在 DOM 中（不能使用 wx:if），否则选择器找不到节点 -->
    <view class="step-card" hidden="{{!imageSelected}}">
      <view class="step-header">
        <text class="step-num">②</text>
        <text class="step-title">点阵预览（32×32）</text>
      </view>
      <view class="canvas-wrapper">
        <canvas type="2d" id="previewCanvas" class="preview-canvas"></canvas>
      </view>

      <!-- 状态提示 -->
      <view class="status-row" wx:if="{{statusText}}">
        <text class="status-icon">{{processing ? '⏳' : (hasError ? '❌' : '✅')}}</text>
        <text class="status-text {{processing ? 'status-processing' : (hasError ? 'status-error' : 'status-success')}}">
          {{statusText}}
        </text>
      </view>
      <view class="status-row" wx:if="{{pixelCountText}}">
        <text class="status-icon">📊</text>
        <text class="status-text status-info">{{pixelCountText}}</text>
      </view>
    </view>

    <!-- 步骤3：蓝牙连接 -->
    <view class="step-card">
      <view class="step-header">
        <text class="step-num">③</text>
        <text class="step-title">蓝牙同步</text>
      </view>

      <!-- 蓝牙状态指示 -->
      <view class="ble-status-bar" wx:if="{{bleStatusText}}">
        <text class="ble-status-dot {{bleConnected ? 'dot-green' : (bleScanning ? 'dot-yellow' : 'dot-gray')}}"></text>
        <text class="ble-status-label">{{bleStatusText}}</text>
      </view>

      <!-- 寻找印章按钮 -->
      <button class="btn btn-scan" bindtap="startScan" 
              disabled="{{bleScanning || bleConnected || processing}}"
              loading="{{bleScanning}}">
        🔍 {{bleScanning ? '正在扫描...' : '寻找印章'}}
      </button>

      <!-- 停止扫描按钮 -->
      <button class="btn btn-stop" bindtap="stopScan" wx:if="{{bleScanning}}">
        ⏹ 停止扫描
      </button>

      <!-- 蓝牙设备列表 -->
      <view class="device-list" wx:if="{{bleDevices.length > 0 && !bleConnected}}">
        <view class="device-list-title">发现以下设备：</view>
        <view class="device-item" 
              wx:for="{{bleDevices}}" 
              wx:key="deviceId"
              bindtap="connectDevice"
              data-deviceid="{{item.deviceId}}"
              data-name="{{item.name}}"
              hover-class="device-item-hover">
          <view class="device-info">
            <text class="device-name">{{item.name}}</text>
            <text class="device-id">ID: {{item.deviceId.substring(0, 8)}}...</text>
          </view>
          <view class="device-signal">
            <text class="device-rssi">{{item.RSSI}} dBm</text>
          </view>
        </view>
      </view>

      <!-- 已连接提示 -->
      <view class="connected-info" wx:if="{{bleConnected}}">
        <text class="connected-icon">🔗</text>
        <text class="connected-text">已连接到 {{connectedDeviceName || '印章设备'}}</text>
      </view>

      <!-- 断开连接按钮 -->
      <button class="btn btn-disconnect" bindtap="disconnectDevice" wx:if="{{bleConnected}}">
        🔌 断开连接
      </button>

      <!-- 同步至印章按钮 -->
      <button class="btn btn-sync" bindtap="sendData" 
              wx:if="{{bleConnected && pixelArray}}"
              disabled="{{isSending}}"
              loading="{{isSending}}">
        📡 同步至印章
      </button>
    </view>

  </view>

  <!-- ========== 底部信息 ========== -->
  <view class="footer">
    <text class="footer-text">AI Smart Stamp  v1.2  |  32×32  |  {{processMode === 'dither' ? '照片' : (processMode === 'edge-aware' ? '边缘感知' : '徽章')}}模式</text>
  </view>

</view>
