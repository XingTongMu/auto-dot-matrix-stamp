.cropper-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.85);
  z-index: 99999;
  display: flex;
  flex-direction: column;
}
.cropper-overlay.show {
  pointer-events: auto;
}

.cropper-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  background: #1a1a1a;
}
.toolbar-btn {
  font-size: 30rpx;
  padding: 12rpx 20rpx;
  min-width: 120rpx;
  text-align: center;
}
.toolbar-btn.cancel { color: #999; }
.toolbar-btn.confirm { color: #fff; background: #4A90D9; border-radius: 8rpx; font-weight: 600; }
.toolbar-title { color: #ccc; font-size: 28rpx; }

.cropper-canvas-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.cropper-canvas {
  width: 750rpx;
  height: 750rpx;
  display: block;
}
