/* ===== ink-splash.wxss —— 泼墨组件样式 ===== */

.ink-splash-container {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  margin-top: 20rpx;
  flex-shrink: 0;
}

/* 标题栏 */
.ink-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.ink-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e50;
}

.ink-actions {
  display: flex;
  gap: 12rpx;
}

.ink-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  background: #f5f5f5;
  border: 2rpx solid #cfd8dc;
  border-radius: 20rpx;
}

.ink-btn:active {
  opacity: 0.7;
  transform: scale(0.95);
}

.ink-btn.disabled {
  opacity: 0.4;
}

.ink-btn-icon {
  font-size: 24rpx;
}

.ink-btn-label {
  font-size: 22rpx;
  color: #546e7a;
  font-weight: 500;
}

/* 提示 */
.ink-hint {
  background: #fff8e1;
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 16rpx;
}

.ink-hint-text {
  font-size: 22rpx;
  color: #795548;
  line-height: 1.5;
}

/* Canvas 外层容器（用于定位油漆桶光标） */
.ink-canvas-wrapper {
  position: relative;
}

/* Canvas */
.ink-canvas {
  width: 100%;
  height: 600rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

/* 油漆桶光标（浮动指针） */
.paint-cursor {
  position: fixed;
  z-index: 999;
  font-size: 48rpx;
  pointer-events: none;
  transform: translate(-50%, -50%);
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}
